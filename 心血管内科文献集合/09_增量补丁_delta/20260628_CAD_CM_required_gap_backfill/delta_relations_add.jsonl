{"id":"REL-C2C1E9AB204D0190","source_code":"DIS-CARD-CAD-CCS","relationType":"has_diagnostic_criteria","target_code":"DXC-CARD-CAD-CCS-CURATED-20260628","relationCategory":"diagnostic","batch_id":"BATCH-CARD-CAD-20260623-001","schema_version":"V1.1","review_status":"approved","polarity":"positive","scope_type":"category","scope_target":"冠状动脉粥样硬化性心脏病","merge_status":"validated","conflict_status":"none","source_quality":"curated_required_gap_backfill","provenance_records_json":[{"document_id":"DOC-C0BB559FA2C8448A","segment_id":"SEG-DOC-C0BB559FA2C8448A-263-TB-00041-CCS","source_name":"《内科学（第10版）》.pdf","source_type":"authoritative_textbook","source_version":"第10版","source_section":"diagnosis_criteria","source_page":263,"evidence_text":"慢性冠脉综合征包括伴稳定心绞痛症状和/或呼吸困难的疑似冠心病病人、新发心力衰竭或左心室功能障碍的疑似冠心病病人、ACS后1年内或近期血运重建后无症状或症状稳定病人、初次诊断或血运重建1年以上的无症状或有症状病人、疑似血管痉挛或微血管疾病的心绞痛病人，以及筛查时发现的无症状CAD病人。","guideline_id":"GL-CARD-INTERNAL-MEDICINE-10","evidence_id":"EVD-CURATED-CAD-CCS-DX-20260628-01","recommendation_class":"N/A","evidence_level":"N/A","confidence":0.86},{"document_id":"DOC-C0BB559FA2C8448A","segment_id":"SEG-DOC-C0BB559FA2C8448A-269-TB-00060-CCS","source_name":"《内科学（第10版）》.pdf","source_type":"authoritative_textbook","source_version":"第10版","source_section":"diagnosis_criteria","source_page":269,"evidence_text":"未捕捉到发作时ECG者可行ECG负荷试验。冠脉CTA有助于无创性评价冠脉管腔狭窄程度及管壁病变性质和分布。冠脉造影可明确病变的严重程度和分布范围，联合腔内影像和功能学技术，有助于诊断和指导进一步治疗。","guideline_id":"GL-CARD-INTERNAL-MEDICINE-10","evidence_id":"EVD-CURATED-CAD-CCS-DX-20260628-02","recommendation_class":"N/A","evidence_level":"N/A","confidence":0.86}],"evidence_ids":["EVD-CURATED-CAD-CCS-DX-20260628-01","EVD-CURATED-CAD-CCS-DX-20260628-02"],"document_ids":["DOC-C0BB559FA2C8448A"],"source_names":["《内科学（第10版）》.pdf"],"source_types":["authoritative_textbook"],"evidence_count":2,"clinical_review_status":"pending_clinical_review","formal_cdss_ready":false,"backfill_reason":"required_pathway_gap_with_textbook_or_guideline_evidence","document_id":"DOC-C0BB559FA2