    },
    {
      "code": "CARD-SKELETON-20260709-DIAGNOSISCRITERIACOMPONENT-4AEEDE8C8A83A808",
      "name": "脑钠肽诊断心衰的敏感性、特异性、阴性预测值和阳性预测值均较高",
      "batch_id": "CARD-SKELETON-20260709",
      "scope_target": null,
      "skeleton_slot": null,
      "knowledge_layer": "textbook_skeleton"
    },
    {
